# Database — never commit (will contain encrypted PII blobs; Article IV)
constructor.db
constructor.db-journal
constructor.db-wal
constructor.db-shm

# Secrets — encryption key lives in env/secret store, never in git (Article IV)
.env
.env.*
# …but the keyless template IS committed (documents CONSTRUCTOR_PII_KEY format)
!.env.example

